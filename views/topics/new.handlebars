<div class="form-page">
  <div class="form-card">
    <h1>Start a New Topic</h1>
    <p class="auth-subtitle">You will be automatically subscribed to topics you create.</p>

    {{#if errors}}
    <div class="alert alert-error">
      {{#each errors}}<p>{{this}}</p>{{/each}}
    </div>
    {{/if}}

    <form action="/topics" method="POST">
      <div class="form-group">
        <label for="title">Topic Title <span class="required">*</span></label>
        <input type="text" id="title" name="title" value="{{formTitle}}"
               placeholder="What's this topic about?" required maxlength="100" />
        <small class="form-hint">3–100 characters</small>
      </div>
      <div class="form-group">
        <label for="description">Description <span class="optional">(optional)</span></label>
        <textarea id="description" name="description" rows="3"
                  placeholder="Give a brief description of this topic..."
                  maxlength="300">{{description}}</textarea>
        <small class="form-hint">Up to 300 characters</small>
      </div>
      <div class="form-actions">
        <a href="/topics" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn">Create Topic</button>
      </div>
    </form>
  </div>
</div>
