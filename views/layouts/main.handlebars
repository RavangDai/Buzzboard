<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}} — Buzzboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Syne+Mono&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <nav class="navbar">
    <div class="nav-brand">
      <a href="{{#if isLoggedIn}}/dashboard{{else}}/auth/login{{/if}}">
        <span class="nav-logo">BB</span>
        BUZZBOARD
      </a>
    </div>

    {{#if isLoggedIn}}
    <div class="nav-links">
      <a href="/dashboard">Dashboard</a>
      <a href="/topics">Topics</a>
      <a href="/topics/new">+ New Topic</a>
      <a href="/stats">Stats</a>
      <span class="nav-user">{{currentUser.username}}</span>
      <a href="/auth/logout" class="btn btn-sm btn-outline">Logout</a>
    </div>
    {{else}}
    <div class="nav-links">
      <a href="/auth/login">Sign In</a>
      <a href="/auth/register" class="btn btn-sm">Register</a>
    </div>
    {{/if}}
  </nav>

  <main class="container">
    {{{body}}}
  </main>

  <footer class="footer">
    BUZZBOARD &mdash; P1 &mdash; MVC + Observer + Singleton
  </footer>
</body>
</html>
